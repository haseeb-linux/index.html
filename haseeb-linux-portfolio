<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Muhammad Haseeb | Portfolio</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      background: #0f0f0f;
      color: #f5f5f5;
      line-height: 1.6;
    }

    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem;
    }

    /* Header / Hero Section */
    .hero {
      text-align: center;
      padding: 4rem 0 3rem;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .hero h1 {
      font-size: 3rem;
      background: linear-gradient(135deg, #fff, #aaa);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      margin-bottom: 0.5rem;
    }

    .badge {
      display: inline-block;
      background: #1e2a3a;
      padding: 0.4rem 1rem;
      border-radius: 40px;
      font-size: 0.8rem;
      margin: 1rem 0;
      border: 1px solid #2d3e50;
      color: #9cdbff;
    }

    .hero p {
      color: #bbb;
      max-width: 600px;
      margin: 0 auto;
    }

    /* Cards & Sections */
    section {
      margin: 4rem 0;
    }

    h2 {
      font-size: 1.8rem;
      margin-bottom: 1.5rem;
      letter-spacing: -0.5px;
      border-left: 4px solid #e74c3c;
      padding-left: 1rem;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .card {
      background: #1a1a1a;
      padding: 1.5rem;
      border-radius: 20px;
      border: 1px solid #2a2a2a;
      transition: transform 0.2s, border-color 0.2s;
    }

    .card:hover {
      border-color: #e74c3c;
      transform: translateY(-4px);
    }

    .skill-tag {
      display: inline-block;
      background: #2a2a2a;
      padding: 0.3rem 0.8rem;
      border-radius: 30px;
      font-size: 0.75rem;
      margin: 0.25rem;
      border: 1px solid #3a3a3a;
    }

    .info-line {
      margin: 0.8rem 0;
    }

    .info-label {
      font-weight: bold;
      color: #e74c3c;
      display: inline-block;
      width: 100px;
    }

    hr {
      border: none;
      height: 1px;
      background: #2a2a2a;
      margin: 2rem 0;
    }

    .footer {
      text-align: center;
      padding: 2rem 0;
      border-top: 1px solid #1f1f1f;
      font-size: 0.85rem;
      color: #777;
    }

    a {
      color: #e74c3c;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    @media (max-width: 700px) {
      .container {
        padding: 1rem;
      }
      .hero h1 {
        font-size: 2rem;
      }
    }
  </style>
</head>
<body>
